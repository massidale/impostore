{
  "rules": {
    ".read": false,
    ".write": false,

    "rooms": {
      "$roomId": {
        ".read":  "auth != null && $roomId.matches(/^[A-Z0-9]{6}$/)",

        ".write": "auth != null && $roomId.matches(/^[A-Z0-9]{6}$/) && (newData.exists() || auth.uid === data.child('hostId').val())",

        ".validate": "!newData.exists() || newData.hasChildren(['id', 'status', 'hostId', 'createdAt', 'updatedAt', 'currentGameId'])",

        "id": {
          ".validate": "newData.isString() && newData.val() === $roomId"
        },
        "status": {
          ".validate": "newData.isString() && (newData.val() === 'lobby' || newData.val() === 'active')"
        },
        "hostId": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 128 && (data.exists() ? data.val() === newData.val() : newData.val() === auth.uid)"
        },
        "createdAt": {
          ".validate": "newData.isNumber() && (!data.exists() || data.val() === newData.val())"
        },
        "updatedAt": {
          ".validate": "newData.isNumber()"
        },
        "currentGameId": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 40"
        },

        "players": {
          "$uid": {
            ".validate": "!newData.exists() || newData.hasChild('joinedAt')",

            "joinedAt": { ".validate": "newData.isNumber()" },
            "name":     { ".validate": "newData.val() === null || (newData.isString() && newData.val().length <= 30)" },
            "isHost":   { ".validate": "newData.isBoolean()" },
            "role":     { ".validate": "newData.val() === null || (newData.isString() && newData.val().matches(/^(civilian|impostor|clown)$/))" },
            "isFirst":  { ".validate": "newData.isBoolean()" },
            "revealed": { ".validate": "newData.isBoolean()" },
            "eliminated": { ".validate": "newData.isBoolean()" },
            "word":     { ".validate": "newData.val() === null || (newData.isString() && newData.val().length <= 60)" },
            "submittedWord": { ".validate": "newData.val() === null || (newData.isString() && newData.val().length >= 1 && newData.val().length <= 60)" },

            "$other": { ".validate": false }
          }
        },

        "gameState": {
          ".validate": true
        },

        "$other": { ".validate": false }
      }
    }
  }
}
